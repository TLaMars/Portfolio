---
import ModuleRenderer from "../../components/ModuleRenderer.astro";
import WorkHeader from "../../components/WorkHeader.astro";
import { works } from "../../data";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const { name, shortDescription, modules } = work;
---

<Layout title={`Thomas Lamars | ${name}`}>
  <WorkHeader title={name} subtitle={shortDescription} />

  {modules.map((module) => <ModuleRenderer module={module} />)}
</Layout>
