---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import InfoModule from "../components/page-modules/InfoModule.astro";

type UnsplashPhoto = {
  id: string;
  urls: { regular: string; small: string };
  links: { html: string };
  alt_description: string | null;
  description: string | null;
  width: number;
  height: number;
  likes: number;
  created_at: string;
  statistics?: {
    views: { total: number };
    downloads: { total: number };
  };
};

const accessKey = import.meta.env.UNSPLASH_ACCESS_KEY;
let photos: UnsplashPhoto[] = [];

if (accessKey) {
  try {
    const response = await fetch(
      `https://api.unsplash.com/users/tlamars/photos?per_page=20&order_by=latest&stats=true`,
      {
        headers: {
          Authorization: `Client-ID ${accessKey}`,
        },
      },
    );

    if (response.ok) {
      photos = await response.json();
    }
  } catch (e) {
    // Silently fail — photos will be empty
  }
}
---

<Layout title="Thomas Lamars | Photography">
  <PageHeader title="Photography" marginSize="sub-page" />

  <InfoModule
    info={[
      { title: "Camera", description: "Nikon Z5II" },
      { title: "Location", description: "Alkmaar, Netherlands" },
      { title: "Unsplash", description: "@tlamars", href: "https://unsplash.com/@tlamars" },
    ]}
  />

  {
    photos.length > 0 ? (
      <>
        <div class="photo-grid">
          {photos.map((photo) => (
            <a
              href={photo.links.html}
              target="_blank"
              rel="noopener noreferrer"
              class="photo-link"
            >
              <img
                src={photo.urls.regular}
                alt={photo.alt_description || photo.description || "Photo"}
                width={photo.width}
                height={photo.height}
                loading="lazy"
              />
              <div class="photo-overlay">
                <span class="photo-author">Thomas Lamars</span>
                <div class="photo-bottom">
                  {(photo.alt_description || photo.description) && (
                    <p class="photo-description">
                      {photo.alt_description || photo.description}
                    </p>
                  )}
                  <div class="photo-meta">
                    {photo.statistics && <span>{photo.statistics.views.total.toLocaleString()} views</span>}
                    {photo.statistics && <span>{photo.statistics.downloads.total.toLocaleString()} downloads</span>}
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>

        <a
          href="https://unsplash.com/@tlamars"
          target="_blank"
          rel="noopener noreferrer"
          class="unsplash-link"
        >
          More on Unsplash &rarr;
        </a>
      </>
    ) : (
      <p class="empty">No photos to show yet.</p>
    )
  }
</Layout>

<style lang="scss">
  @use "../styles/utils" as *;

  .photo-grid {
    max-width: var(--content-page-width-extra-large);
    width: 100%;
    columns: 4;
    column-gap: 1.6rem;
    margin-bottom: var(--content-page-gap);

    @include tablet-only {
      columns: 3;
    }

    @include phone-only {
      columns: 2;
      margin-bottom: var(--content-page-gap-mobile);
    }
  }

  .photo-link {
    display: block;
    position: relative;
    margin-bottom: 1.6rem;
    break-inside: avoid;
    overflow: hidden;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);

      .photo-overlay {
        opacity: 1;
      }
    }

    @include phone-only {
      margin-bottom: 1.6rem;
    }
  }

  img {
    width: 100%;
    height: auto;
    display: block;
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.4rem;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5) 0%,
      rgba(0, 0, 0, 0) 30%,
      rgba(0, 0, 0, 0) 50%,
      rgba(0, 0, 0, 0.7) 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;

    @include phone-only {
      padding: 1.6rem;
    }
  }

  .photo-author {
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-bold);
    color: var(--white);
  }

  .photo-description {
    font-size: var(--font-size-s);
    color: var(--white);
    margin: 0 0 0.8rem;
    line-height: 150%;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .photo-meta {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.7);
  }

  .photo-meta span {
    font-size: var(--font-size-xs);
    line-height: 1;
  }

  .unsplash-link {
    display: block;
    text-align: center;
    margin-bottom: var(--content-page-gap);
    font-size: var(--font-size-s);
    color: var(--foreground-accent);
    text-decoration: none;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.8;
      color: var(--foreground-accent);
    }

    @include phone-only {
      margin-bottom: var(--content-page-gap-mobile);
    }
  }

  .empty {
    text-align: center;
    opacity: 0.5;
    margin-bottom: var(--content-page-gap);
  }
</style>
