---
import NavLink from "./NavLink.astro";

// Static builds emit routes as directories (/about/index.html), so pathname often
// includes a trailing slash. Dev uses no trailing slash — normalize for comparisons.
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<nav>
  <NavLink href="/" label="Home" active={pathname === "/"} />
  <NavLink href="/about" label="About" active={pathname === "/about"} />
  <NavLink href="/photography" label="Photography" active={pathname === "/photography"} />
</nav>

<style lang="scss">
  nav {
    position: fixed;
    margin-top: 1.6rem;
    display: flex;
    background: var(--background-opaque);
    padding: 0.4rem;
    border-radius: 5rem;
    backdrop-filter: blur(1.4rem);
    gap: 0.4rem;
    z-index: 1;
  }
</style>
