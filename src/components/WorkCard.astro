---
import type { ImageMetadata } from "astro";
import ArrowRight from "../assets/svgs/arrow-right.svg";
import type { ImagePosition } from "../models/work";
import { Image } from "astro:assets";

type Props = {
  title: string;
  subtitle: string;
  image: ImageMetadata;
  imagePosition?: ImagePosition;
  variant?: "blue" | "green" | "purple";
  slug: string;
  externalUrl?: string;
  comingSoon?: boolean;
  size?: "small" | "large";
};

const {
  title,
  subtitle,
  image,
  imagePosition = "fill",
  variant = "blue",
  slug,
  externalUrl,
  comingSoon = false,
  size = "large",
} = Astro.props;

const href = externalUrl ?? slug;
const linkProps = externalUrl
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<a class:list={["card", variant, size]} href={href} {...linkProps}>
  <p class="subtitle">{subtitle}</p>
  <h2 class="title">{title}</h2>
  <div class="image-holder">
    <Image class:list={["image", imagePosition]} src={image} alt={title} />
  </div>

  {comingSoon && <span class:list={["fab-label", variant]}>Soon</span>}
  <div class:list={["fab", variant]}>
    <ArrowRight />
  </div>
</a>

<style lang="scss">
  @use "../styles/utils" as *;

  .card {
    position: relative;
    padding: 3.2rem 4.8rem;
    border-radius: 4.8rem;
    height: 38rem;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;

    &.small {
      height: 30rem;
    }

    &:hover,
    &.touch-active {
      color: var(--foreground);
      transform: translateY(-4px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);

      // .fab {
      //   transform: translateX(10px);
      // }
    }

    &.green {
      background: var(--background-surface-1);
    }

    &.blue {
      background: var(--background-surface-2);
    }

    &.purple {
      background: var(--background-surface-3);
    }

    @include phone-only {
      height: 30rem;
      padding: 2.4rem 3.4rem;
      border-radius: 3.4rem;
    }
  }

  .subtitle {
    font-size: var(--font-size-s);
    margin: 0;
    margin-bottom: 0.4rem;
    text-align: right;

    @include phone-only {
      font-size: var(--font-size-xs);
    }
  }

  .title {
    font-size: var(--font-size-xl);
    margin-top: 0;
    margin-bottom: 3.2rem;
    text-align: right;

    @include phone-only {
      font-size: var(--font-size-l);
      margin-bottom: 2.4rem;
    }
  }

  .image-holder {
    position: relative;
    width: 100%;
    transition: transform 0.3s ease;
  }

  .card:hover .image-holder,
  .card.touch-active .image-holder {
    transform: translateY(12px);
  }

  .image {
    height: unset;
    &.center {
      width: 100%;
    }

    &.fill {
      max-width: 96rem;
    }
  }

  .fab {
    position: absolute;
    right: 3.8rem;
    bottom: 3.8rem;
    border-radius: 50%;
    width: 6.4rem;
    height: 6.4rem;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: transform 0.3s ease;

    &.green {
      background: var(--background-button-1);
    }

    &.blue {
      background: var(--background-button-2);
    }

    &.purple {
      background: var(--background-button-3);
    }

    @include phone-only {
      width: 4.8rem;
      height: 4.8rem;
      right: 2.4rem;
      bottom: 2.4rem;

      :global(svg) {
        width: 3.6rem;
        height: 3.6rem;
      }
    }
  }

  .fab-label {
    position: absolute;
    z-index: 1;
    left: 3.8rem;
    bottom: 3.8rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 1rem 1.6rem;
    border-radius: 10rem;
    white-space: nowrap;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;

    &.green {
      background: var(--background-button-1);
    }

    &.blue {
      background: var(--background-button-2);
    }

    &.purple {
      background: var(--background-button-3);
    }

    @include phone-only {
      left: 2.4rem;
      bottom: 2.4rem;
      padding: 0.6rem 1.2rem;
      font-size: 1rem;
    }
  }
</style>
